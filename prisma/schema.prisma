generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  imageUrl    String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photo {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id         String   @id @default(cuid())
  title      String
  videoUrl   String?
  thumbnail  String?
  category   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sourceType String   @default("youtube")
  youtubeUrl String?
}

model Enterprise {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  buttonHref  String?
  buttonText  String?
  isActive    Boolean  @default(true)
  location    String?
  profileUrl  String?
  sortOrder   Int      @default(0)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  queryType String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model AdminUser {
  id                     String   @id @default(cuid())
  email                  String   @unique
  password               String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  isActive               Boolean  @default(true)
  isProtected            Boolean  @default(false)
  name                   String?
  role                   String   @default("admin")
  isHiddenFromAdminPanel Boolean  @default(false)
}

model SocialLink {
  id        String   @id @default(cuid())
  label     String   @unique
  href      String
  iconUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeSlide {
  id         String   @id @default(cuid())
  title      String?
  subtitle   String?
  imageUrl   String
  buttonText String?
  buttonHref String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OfficeSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  address   String
  phone     String
  email     String
  mapUrl    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BoardDirector {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  role           String
  education      String?
  shortMessage   String?
  image          String?
  facebook       String?
  whatsapp       String?
  profileEnabled Boolean  @default(false)
  isActive       Boolean  @default(true)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
}

model EnterpriseProject {
  id               String   @id @default(cuid())
  enterpriseSlug   String
  slug             String
  name             String
  location         String?
  image            String?
  shortDescription String?
  fullDescription  Json?
  media            Json?
  profilePdf       String?
  websiteUrl       String?
  tour360Image     String?
  isActive         Boolean  @default(true)
  displayOrder     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([enterpriseSlug, slug])
}

model ClientLoginSetting {
  id           String   @id @default("main")
  buttonText   String   @default("Client Login")
  buttonUrl    String   @default("")
  isEnabled    Boolean  @default(false)
  openInNewTab Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model WebsiteLogoSetting {
  id        String   @id @default("main")
  logoUrl   String   @default("/images/logos/Asset 14.png")
  altText   String   @default("Real Capita Group")
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model BrandLogo {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model SeoSetting {
  id                     String   @id @default("main")
  siteTitle              String   @default("Real Capita Group")
  metaDescription        String   @default("")
  metaKeywords           String   @default("")
  ogTitle                String   @default("")
  ogDescription          String   @default("")
  ogImage                String   @default("")
  googleVerificationCode String   @default("")
  allowIndexing          Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt
}

model AboutPageContent {
  id         String   @id
  pageKey    String   @unique
  title      String
  imageUrl   String
  paragraphs Json     @default("[]")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}
