generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  imageUrl    String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Photo {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String
  thumbnail String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Enterprise {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  queryType String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}